# Copiá este archivo a .env y ajustá lo que necesites.
# docker compose lee .env automáticamente.

# --- Puerto público de la app (frontend nginx) ---
WEB_PORT=8080

# --- Postgres ---
POSTGRES_DB=cauce
POSTGRES_USER=cauce
POSTGRES_PASSWORD=cauce

# --- Django ---
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=cambia-esta-clave-en-produccion
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Sembrar datos de demo en el primer arranque (1 = sí, 0 = no).
SEED_DEMO=1
